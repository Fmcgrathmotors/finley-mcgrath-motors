# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real API keys.

# Required to actually send lead emails. Without this, /api/quote still
# works and logs submissions to the server console, but sends no email.
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=

# Where new leads get emailed. Defaults to the address in lib/site.ts if unset.
LEAD_NOTIFICATION_EMAIL=hello@finleymcgrathmotors.com

# The "from" address Resend sends as. Must be on a domain you've verified
# in Resend (https://resend.com/domains). Until you verify a domain, leave
# this unset to use Resend's shared sandbox sender (onboarding@resend.dev),
# which can only deliver to the email address you signed up to Resend with.
RESEND_FROM_EMAIL="Finley McGrath Motors <leads@finleymcgrathmotors.com>"
